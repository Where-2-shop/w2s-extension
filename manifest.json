{
  "manifest_version": 3,
  "name": "Where2Shop",
  "short_name": "W2S",
  "version": "1.0.0",
  "description": "Compare Coles, Woolworths & Aldi — auto-fill your cart at the cheapest store.",

  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://app.where2shop.crea-dapp.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://api.where2shop.crea-dapp.com/*",
    "https://www.woolworths.com.au/*",
    "https://www.coles.com.au/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://app.where2shop.crea-dapp.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content/where2shop.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.woolworths.com.au/*"],
      "js": ["content/woolworths.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.coles.com.au/*"],
      "js": ["content/coles.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Where2Shop",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
